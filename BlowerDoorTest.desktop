[Desktop Entry]
Type=Application
Name=BlowerDoorTest
Comment=Run blower door test GUI
# 앱이 어떤 이유로 끝나든(크래시 포함) 팬 duty 0 을 후행으로 보장한다.
# atexit 은 정상 종료에서만 돌고, sysfs PWM 설정은 프로세스가 죽어도 커널에
# 남아 팬이 마지막 duty 로 계속 돌기 때문이다.
Exec=sh -c "/usr/bin/python3 -m bdt; /usr/bin/python3 -m bdt.fan_stop"
Path=/home/phiko/Blower_Door_Test_Calculator
Icon=/home/phiko/Blower_Door_Test_Calculator/icon.png
Terminal=true
Categories=Science;
